{
  "version": 6,
  "configurePresets": [
    {
      "name": "host",
      "displayName": "Host (macOS/Linux 단위 테스트용)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/host",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TCE_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "ios-device",
      "displayName": "iOS arm64 device",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/ios-device",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0",
        "CMAKE_OSX_SYSROOT": "iphoneos",
        "TCE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "ios-sim",
      "displayName": "iOS Simulator (arm64 + x86_64)",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/ios-sim",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "TCE_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "host",       "configurePreset": "host" },
    { "name": "ios-device", "configurePreset": "ios-device", "configuration": "Release" },
    { "name": "ios-sim",    "configurePreset": "ios-sim",    "configuration": "Release" }
  ],
  "testPresets": [
    { "name": "host", "configurePreset": "host", "output": { "outputOnFailure": true } }
  ]
}
